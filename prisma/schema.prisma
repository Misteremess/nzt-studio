generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Modelo técnico mínimo para validar la conexión y la migración inicial.
// Los modelos de negocio reales se definen en NZT-19.
model SystemHealthCheck {
  id        String   @id @default(cuid())
  status    String
  createdAt DateTime @default(now())

  @@map("system_health_checks")
}
