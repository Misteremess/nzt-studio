generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum CompanyStatus {
  PROSPECT      // Identificada, no analizada
  ACTIVE        // En análisis o seguimiento activo
  PROPOSAL_SENT // Propuesta enviada
  CLIENT        // Cliente firmado
  INACTIVE      // Sin actividad
}

enum OpportunityStatus {
  DETECTED   // Detectada desde análisis
  VALIDATED  // Confirmada como oportunidad real
  PROPOSED   // Incluida en propuesta
  ACCEPTED   // Cliente aceptó
  REJECTED   // Cliente rechazó
  CLOSED     // Cerrada por otro motivo
}

enum ProposalStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum PromptTemplateType {
  ANALYSIS
  OPPORTUNITY
  MVP_SPEC
  PROPOSAL
  PRICING
  KNOWLEDGE
  GENERAL
}

enum AiRunType {
  ANALYSIS
  OPPORTUNITY_DETECTION
  MVP_SPEC_GENERATION
  PROPOSAL_GENERATION
  PRICING
  GENERAL
}

enum KnowledgeItemType {
  TEMPLATE    // Plantillas de documentos
  PROMPT      // Referencias de prompts
  GUIDE       // Guías internas
  REFERENCE   // Referencias externas
  CASE_STUDY  // Casos de uso
  SNIPPET     // Fragmentos de código o contenido
}

// Estado de entrega de un MVP vendido (Delivery Workspace).
enum DeliveryStatus {
  QUEUED       // En cola — decidido construir, aún sin empezar
  IN_PROGRESS  // En construcción
  IN_REVIEW    // En revisión / QA con el cliente
  DELIVERED    // Entregado
  ON_HOLD      // En pausa
  CANCELLED    // Cancelado
}

// Tipo de reunión propuesta en un correo generado (Email Generator).
enum EmailMeetingType {
  NONE       // No se propone ninguna reunión
  CALL       // Llamada telefónica
  VIDEO_CALL // Videollamada (Teams)
  IN_PERSON  // Reunión presencial
}

// Canal por el que opera un agente de IA propio (AI Agents).
enum AiAgentChannel {
  WHATSAPP // WhatsApp Business
  EMAIL    // Correo
  PHONE    // Llamadas (ElevenLabs)
}

// Estado operativo de un agente de IA propio (AI Agents).
enum AiAgentStatus {
  ACTIVE // En producción, atendiendo
  PAUSED // Desactivado temporalmente
  DRAFT  // En configuración / pruebas
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

// Usuario con acceso al cockpit privado. Reemplaza al admin único por env vars.
// Cada usuario tiene su propia contraseña (bcrypt) y su propio 2FA (TOTP /
// Google Authenticator). El secreto TOTP se guarda cifrado en reposo (AES-256-
// GCM, ver lib/auth/secret-crypto.ts). No hay registro público: las cuentas se
// crean con scripts/manage-users.ts.
model User {
  id           String  @id @default(cuid())
  email        String  @unique
  name         String
  passwordHash String // bcrypt
  totpSecret   String? // base32 cifrado; null hasta iniciar el enrolamiento 2FA
  totpEnabled  Boolean @default(false) // true solo tras confirmar el primer código
  role         String  @default("member") // "admin" | "member" — reservado para el futuro

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// ─── Technical ────────────────────────────────────────────────────────────────

// Tabla de validación técnica creada en NZT-18. Se mantiene por historial.
model SystemHealthCheck {
  id        String   @id @default(cuid())
  status    String
  createdAt DateTime @default(now())

  @@map("system_health_checks")
}

// ─── Core domain ──────────────────────────────────────────────────────────────

model Company {
  id       String        @id @default(cuid())
  name     String
  sector   String?
  city     String?
  website  String?
  phone    String? // PII — mantener opcional, no añadir más datos personales
  email    String? // PII — mantener opcional
  mapsUrl  String?
  notes    String?
  status   CompanyStatus @default(PROSPECT)

  // ── Seguimiento comercial (pipeline) ──────────────────────────────────────
  lastContactAt DateTime? // Último contacto comercial registrado manualmente
  nextAction    String?   // Próxima acción de venta planificada (texto libre)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  analyses      Analysis[]
  opportunities Opportunity[]
  proposals     Proposal[]
  projects      Project[]
  placeCache    PlaceCache?   // Populated if this Company was discovered via the Analyzer

  @@map("companies")
}

model MarketResearch {
  id           String   @id @default(cuid())
  sector       String
  city         String?
  targetTicket Int? // Ticket objetivo en EUR
  findings     Json? // Hallazgos estructurados del mercado
  ideas        Json? // Array de ideas detectadas
  score        Int? // Puntuación 0-100 del atractivo del nicho
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("market_researches")
}

model Analysis {
  id        String   @id @default(cuid())
  companyId String
  url       String? // URL analizada
  rawData   Json? // Datos crudos del scraping o análisis
  scores    Json? // Dimensiones puntuadas (SEO, UX, tech, etc.)
  aiOutput  Json? // Insights generados por IA
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  opportunities Opportunity[]
  aiRuns        AiRun[]

  @@map("analyses")
}

model Opportunity {
  id         String            @id @default(cuid())
  companyId  String
  analysisId String? // Opcional: puede crearse manualmente sin análisis previo
  title      String
  problem    String?
  solution   String?
  impact     String?
  difficulty String? // "low" | "medium" | "high" — libre para flexibilidad inicial
  price      Decimal?          @db.Decimal(10, 2) // Precio estimado en EUR
  priority   Int               @default(0) // 0-100
  status     OpportunityStatus @default(DETECTED)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  analysis  Analysis? @relation(fields: [analysisId], references: [id], onDelete: SetNull)
  mvpSpecs  MvpSpec[]
  proposals Proposal[]

  @@map("opportunities")
}

model MvpSpec {
  id            String   @id @default(cuid())
  opportunityId String
  name          String
  features      Json? // Array de features con descripción y prioridad
  screens       Json? // Array de pantallas/vistas
  dataSchema    Json? // Modelo de datos propuesto (renombrado de 'schema' — palabra reservada)
  integrations  Json? // Integraciones necesarias
  stack         Json? // Stack tecnológico recomendado
  roadmap       Json? // Fases y milestones
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  proposals   Proposal[]

  @@map("mvp_specs")
}

model Proposal {
  id               String         @id @default(cuid())
  companyId        String
  opportunityId    String? // Opcional: propuesta puede no estar ligada a una oportunidad específica
  mvpSpecId        String?
  content          Json? // Contenido estructurado de la propuesta
  price            Decimal?       @db.Decimal(10, 2)
  maintenancePrice Decimal?       @db.Decimal(10, 2) // Precio mensual de mantenimiento
  status           ProposalStatus @default(DRAFT)
  pdfUrl           String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  mvpSpec     MvpSpec?     @relation(fields: [mvpSpecId], references: [id], onDelete: SetNull)
  project     Project?

  @@map("proposals")
}

model Project {
  id         String        @id @default(cuid())
  companyId  String
  proposalId String?       @unique // Un proyecto por propuesta
  status     ProjectStatus @default(PLANNING)
  startDate  DateTime?
  deadline   DateTime?
  repoUrl    String?
  deployUrl  String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  proposal Proposal? @relation(fields: [proposalId], references: [id], onDelete: SetNull)
  tasks    Task[]

  @@map("projects")
}

model Task {
  id        String       @id @default(cuid())
  projectId String
  title     String
  status    TaskStatus   @default(TODO)
  priority  TaskPriority @default(MEDIUM)
  dueDate   DateTime?
  notes     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("tasks")
}

// ─── AI & Knowledge ───────────────────────────────────────────────────────────

model PromptTemplate {
  id           String             @id @default(cuid())
  name         String
  type         PromptTemplateType
  version      Int                @default(1)
  content      String // Texto completo del prompt
  outputSchema Json? // Esquema esperado del output (para validación)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  aiRuns AiRun[]

  @@unique([name, version])
  @@map("prompt_templates")
}

model AiRun {
  id               String    @id @default(cuid())
  type             AiRunType
  model            String // e.g. "claude-sonnet-4-6", "gpt-4o"
  promptTemplateId String? // Opcional: puede ser un prompt ad hoc
  promptVersion    Int? // Versión del prompt usada en el momento de la ejecución
  analysisId       String? // Opcional: futuro soporte para otros contextos (pricing, proposal...)
  input            Json // Input enviado al modelo
  output           Json? // Output recibido
  cost             Decimal?  @db.Decimal(10, 6) // Coste en USD con precisión de sub-centavo
  createdAt        DateTime  @default(now())

  promptTemplate PromptTemplate? @relation(fields: [promptTemplateId], references: [id], onDelete: SetNull)
  analysis       Analysis?       @relation(fields: [analysisId], references: [id], onDelete: SetNull)

  @@map("ai_runs")
}

model KnowledgeItem {
  id        String            @id @default(cuid())
  type      KnowledgeItemType
  title     String
  content   String
  tags      String[] // Array nativo de PostgreSQL
  embedding Json? // Placeholder para embeddings vectoriales (pgvector en sprint futuro)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@map("knowledge_items")
}

// ─── Analyzer ─────────────────────────────────────────────────────────────────

// Cache de negocios descubiertos via Google Places API (New).
// Fuente: Local Business Analyzer — Sprint 3 (NZT-76+).
// Los datos de búsqueda se guardan al hacer Nearby Search.
// Los datos de detalle se guardan bajo demanda al abrir un negocio.
// Nunca se guarda automáticamente como Company — solo por acción manual del usuario.
model PlaceCache {
  id String @id @default(cuid())

  // ── Identificador de fuente ────────────────────────────────────────────────
  placeId String @unique          // Google Places ID. Inmutable para un lugar dado.
  source  String @default("google_places")

  // ── Datos de búsqueda (disponibles desde Nearby Search) ───────────────────
  name             String
  formattedAddress String?
  latitude         Float
  longitude        Float
  types            String[]  // ["dentist", "health", "point_of_interest", ...]
  primaryType      String?   // Tipo principal del negocio
  businessStatus   String?   // "OPERATIONAL" | "CLOSED_TEMPORARILY" | "CLOSED_PERMANENTLY"
  rating           Float?    // 1.0–5.0
  userRatingCount  Int?      // Número total de reseñas

  // ── Datos de detalle (Place Details, cargados bajo demanda) ───────────────
  websiteUri               String?
  nationalPhone            String?
  internationalPhone       String?
  googleMapsUri            String?
  hasOpeningHours          Boolean  @default(false)
  openingHoursDescriptions String[] // ["Lunes: 9:00–20:00", ...]

  // ── Señales y oportunidades computadas ────────────────────────────────────
  signals       Json? // PlaceSignals — calculado al cargar detalle
  opportunities Json? // DetectedOpportunity[] — calculado al cargar detalle

  // ── Auditoría web (fetch directo a la web del negocio, sin APIs) ──────────
  webAudit          Json?     // WebAuditResult — calculado bajo demanda si hay websiteUri
  webAuditFetchedAt DateTime? // Cuándo se ejecutó la auditoría (null = nunca)

  // ── Respuestas crudas de la API ────────────────────────────────────────────
  rawSearch Json? // Objeto completo recibido de Nearby Search para este place
  rawDetail Json? // Objeto completo recibido de Place Details

  // ── Control de cache ───────────────────────────────────────────────────────
  searchFetchedAt DateTime  @default(now()) // Cuándo se guardó el resultado de búsqueda
  detailFetchedAt DateTime?                 // Cuándo se cargó el detalle (null = no cargado aún)

  // ── Vínculo con CRM (opcional) ────────────────────────────────────────────
  // Null mientras no se guarde como Company candidata.
  // @unique garantiza: un lugar descubierto → máximo una Company en el CRM.
  // onDelete: SetNull — si la Company se elimina, el cache persiste sin vínculo.
  companyId String?  @unique
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([latitude, longitude])
  @@index([searchFetchedAt])
  @@map("place_cache")
}

// ─── AI Business Analysis (Analyzer module) ─────────────────────────────────────

// Análisis de negocio generado por IA (Claude + web_search).
// Fuente: módulo Analyzer. Se vincula a un negocio del Rastreador via placeId.
// Un análisis por placeId (@unique) — se regenera con upsert al re-analizar.
model BusinessAnalysis {
  id      String @id @default(cuid())
  placeId String @unique // Google Places ID — vincula con PlaceCache del Rastreador

  // ── Contexto del negocio en el momento del análisis ───────────────────────
  businessName String
  model        String  // Modelo de IA usado, e.g. "claude-opus-4-7"

  // ── Salida del análisis ───────────────────────────────────────────────────
  summary     String   // Resumen ejecutivo del negocio
  assets      Json     // string[] — "lo que el negocio ya tiene"
  webFindings Json     // { text, sources: {title,url}[] } — investigación en internet
  rawOutput   Json?    // Respuesta cruda de la API para depuración

  archivedAt DateTime? // Null = activo; not-null = archivado (soft-delete)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  opportunities AiOpportunity[]
  brandIdentity BrandIdentity?

  @@map("business_analyses")
}

// Identidad visual real del negocio (colores, tipografía, logo) usada para
// generar mockups HTML fieles a la marca en lugar de paletas inventadas.
// 1:1 con BusinessAnalysis — se detecta una vez y la reutilizan todas las
// oportunidades/MVPs de ese negocio.
model BrandIdentity {
  id         String @id @default(cuid())
  analysisId String @unique

  source    String  // "website" | "logo" | "manual" — origen de la identidad
  sourceUrl String? // URL de la web usada para extraer (si source="website")

  colors      Json    // { role: string; hex: string; label?: string }[]
  fontHeading String? // Nombre de Google Font para títulos
  fontBody    String? // Nombre de Google Font para cuerpo de texto
  styleNotes  String? @db.Text // Tono/personalidad de marca, en texto libre

  logoImage          String? @db.Text // base64 (sin prefijo data:)
  logoImageMime      String?
  referenceImage     String? @db.Text // imagen de brief/inspiración subida manualmente
  referenceImageMime String?

  model String? // Modelo de IA usado para interpretar logo/web (si aplica)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  analysis BusinessAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@map("brand_identities")
}

// Oportunidad de negocio detectada por la IA dentro de un BusinessAnalysis.
// Cuando selected=true, queda disponible para el módulo MVP Factory.
model AiOpportunity {
  id         String @id @default(cuid())
  analysisId String

  title       String
  description String  // Qué es la oportunidad
  development String  // "Qué podríamos hacer" — desarrollo concreto
  impact      String? // "low" | "medium" | "high"
  effort      String? // "low" | "medium" | "high"
  selected    Boolean @default(false) // Marcada para pasar al MVP Factory

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  analysis BusinessAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  mvpSpec  AiMvpSpec?

  @@index([analysisId])
  @@map("ai_opportunities")
}

// Especificación de MVP generada por la IA para una AiOpportunity seleccionada.
// 1:1 con AiOpportunity. Es el resultado del módulo MVP Factory.
model AiMvpSpec {
  id            String @id @default(cuid())
  opportunityId String @unique

  model      String // Modelo de IA usado, e.g. "claude-opus-4-7"
  pitch      String // Frase de venta / one-liner
  problem    String // Problema que resuelve
  solution   String // Solución propuesta
  targetUser String // Usuario objetivo

  coreFeatures   Json // string[] — features imprescindibles del MVP
  futureFeatures Json // string[] — mejoras posteriores (fuera del MVP)
  techStack      Json // string[] — stack tecnológico recomendado
  phases         Json // { title, description }[] — roadmap por fases

  timeline   String // Estimación de tiempo (texto, e.g. "4-6 semanas")
  complexity String? // "low" | "medium" | "high"
  rawOutput  Json? // Respuesta cruda de la API para depuración

  htmlMockup      String? @db.Text // HTML autocontenido del mockup (Tailwind CDN)
  htmlMockupModel String? // Modelo de IA usado para el mockup HTML

  archivedAt DateTime? // Null = activo; not-null = archivado (soft-delete)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  opportunity AiOpportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  pricing     AiPricing?    // Pricing Studio output (1:1)
  proposal    AiProposal?   // Proposal Builder output (1:1)
  delivery    AiDelivery?   // Delivery Workspace tracking (1:1)
  images      AiMvpImage[]  // Mockups de diseño generados por IA (hero/features/detail)

  @@map("ai_mvp_specs")
}

// Mockup de diseño web generado por IA (OpenAI gpt-image) para un AiMvpSpec.
// Hasta 3 por spec (hero, features, detail). Se guarda el PNG en base64 para
// que los diseños persistan entre sesiones sin depender de almacenamiento externo.
model AiMvpImage {
  id        String @id @default(cuid())
  mvpSpecId String

  kind  String // "hero" | "features" | "detail"
  label String // Etiqueta legible, e.g. "Landing (hero)"
  data  String // PNG en base64 (sin prefijo data:)
  model String // Modelo de imagen usado, e.g. "gpt-image-2"

  createdAt DateTime @default(now())

  mvpSpec AiMvpSpec @relation(fields: [mvpSpecId], references: [id], onDelete: Cascade)

  @@unique([mvpSpecId, kind])
  @@map("ai_mvp_images")
}

// Pricing generado por la IA para un AiMvpSpec. 1:1 con AiMvpSpec.
// Es el resultado del módulo Pricing Studio: cómo cobrar este MVP a un negocio
// local (precio de construcción, mantenimiento y planes/tiers), en EUR.
model AiPricing {
  id        String @id @default(cuid())
  mvpSpecId String @unique

  model    String // Modelo de IA usado, e.g. "claude-opus-4-7"
  currency String @default("EUR")

  setupPrice   Int  // Precio único de construcción del MVP (EUR)
  monthlyPrice Int? // Cuota mensual de mantenimiento/hosting (EUR), si aplica

  tiers           Json    // { name, price, billing, description, features[] }[]
  recommendedTier String? // Nombre del plan recomendado
  paymentTerms    String  // Condiciones de pago (e.g. "50% al inicio, 50% a la entrega")
  rationale       String  // Justificación del precio
  assumptions     Json    // string[] — supuestos sobre los que se basa el precio
  saasModel       Json?   // Perspectiva de suscripción mensual (SaaS): { monthlyPrice, annualPrice, setupFee, minimumTermMonths, includedServices[], breakEvenMonths, rationale }
  rawOutput       Json?   // Respuesta cruda de la API para depuración

  archivedAt DateTime? // Null = activo; not-null = archivado (soft-delete)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mvpSpec AiMvpSpec @relation(fields: [mvpSpecId], references: [id], onDelete: Cascade)

  @@map("ai_pricings")
}

// Propuesta comercial generada por la IA para un AiMvpSpec. 1:1 con AiMvpSpec.
// Es el resultado del módulo Proposal Builder: documento listo para enviar al
// negocio, que combina el MVP y (si existe) su pricing.
model AiProposal {
  id        String @id @default(cuid())
  mvpSpecId String @unique

  model String // Modelo de IA usado, e.g. "claude-opus-4-7"

  title            String // Título de la propuesta
  executiveSummary String // Resumen ejecutivo
  problemStatement String // El problema del negocio
  proposedSolution String // La solución propuesta

  scope        Json // string[] — qué incluye el proyecto
  outOfScope   Json // string[] — qué NO incluye
  deliverables Json // string[] — entregables concretos
  phases       Json // { title, description }[] — plan de trabajo
  terms        Json // string[] — términos y condiciones
  nextSteps    Json // string[] — próximos pasos

  investment   String // Resumen de inversión (texto, integra el pricing)
  callToAction String // Cierre / llamada a la acción
  rawOutput    Json?  // Respuesta cruda de la API para depuración

  archivedAt DateTime? // Null = activo; not-null = archivado (soft-delete)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mvpSpec AiMvpSpec @relation(fields: [mvpSpecId], references: [id], onDelete: Cascade)
  callScript AiCallScript?

  @@map("ai_proposals")
}

// Seguimiento de entrega de un MVP a lo largo de su ejecución post-venta.
// 1:1 con AiMvpSpec. Es el corazón del módulo Delivery Workspace. Se crea bajo
// demanda cuando el usuario decide construir/entregar ese MVP.
model AiDelivery {
  id        String @id @default(cuid())
  mvpSpecId String @unique

  status    DeliveryStatus @default(QUEUED)
  repoUrl   String?
  deployUrl String?
  notes     String?

  startedAt   DateTime? // Cuándo pasó a IN_PROGRESS por primera vez
  deliveredAt DateTime? // Cuándo pasó a DELIVERED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mvpSpec AiMvpSpec         @relation(fields: [mvpSpecId], references: [id], onDelete: Cascade)
  tasks   AiDeliveryTask[]

  @@map("ai_deliveries")
}

// Ítem de checklist dentro de una entrega.
model AiDeliveryTask {
  id         String @id @default(cuid())
  deliveryId String

  title    String
  done     Boolean @default(false)
  position Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  delivery AiDelivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([deliveryId])
  @@map("ai_delivery_tasks")
}

// Borrador de correo generado por la IA (Email Generator). Cada registro es un
// correo autocontenido: puede presentar una o varias oportunidades/MVPs (sin
// adjuntarlos), proponer una reunión, o ser totalmente independiente (e.g.
// "vender nuestros servicios de agentes de IA"). No tiene relaciones con otras
// tablas — las referencias a oportunidades/MVPs se guardan como snapshot JSON.
model AiEmailDraft {
  id String @id @default(cuid())

  model String // Modelo de IA usado, e.g. "claude-opus-4-7"

  // ── Entrada (lo que el usuario configuró para generar el correo) ──────────
  objective     String @db.Text // Objetivo del correo, en texto libre
  recipientName String // Nombre del destinatario
  recipientRole String // Cargo del destinatario (puede ir vacío)
  businessName  String // Empresa/negocio destinatario (puede ir vacío para genéricos)
  senderName    String // Quién firma el correo

  meetingType  EmailMeetingType @default(NONE)
  meetingNotes String? // Preferencias de horario/lugar para la reunión propuesta

  references Json // EmailReference[] — oportunidades/MVPs presentados (snapshot)

  // ── Salida ──────────────────────────────────────────────────────────────
  subject   String
  body      String @db.Text
  rawOutput Json? // Respuesta cruda de la API para depuración

  archivedAt DateTime? // Null = activo; not-null = archivado (soft-delete)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ai_email_drafts")
}

// Agente de IA propio de NZT Studio, desplegado para un cliente o uso interno
// (WhatsApp Business, correo o llamadas vía ElevenLabs). Módulo de gestión/CRUD,
// sin generación por IA.
model AiAgent {
  id String @id @default(cuid())

  name        String
  channel     AiAgentChannel
  status      AiAgentStatus @default(ACTIVE)
  description String?       @db.Text // Para qué sirve / qué hace este agente

  clientName String? // Cliente/negocio al que pertenece (vacío si es interno de NZT)

  // ── Config específica de canal ────────────────────────────────────────────
  phoneNumber       String? // Nº de WhatsApp Business / teléfono
  emailAddress      String? // Dirección de correo gestionada
  elevenLabsAgentId String? // ID del agente de voz en ElevenLabs

  notes String? @db.Text // Notas libres (prompts, configuración, incidencias…)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ai_agents")
}

// ─── App settings (key-value) ─────────────────────────────────────────────────
// Single-user app configuration. Used, among other things, to choose which AI
// provider (anthropic | gemini) each module uses. Keys are namespaced, e.g.
// "provider.mvp-factory".
model AppSetting {
  key   String @id
  value String

  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

// ─── Home ───────────────────────────────────────────────────────────────────
// Caches the daily "sector news" web search shown on the Home dashboard so it's
// only generated once per day (one row per UTC date "YYYY-MM-DD").
model HomeNewsCache {
  id       String @id @default(cuid())
  date     String @unique // "YYYY-MM-DD" (UTC)
  items    Json // HomeNewsItem[]
  provider String
  model    String

  createdAt DateTime @default(now())

  @@map("home_news_cache")
}

// ─── Outreach Agent ────────────────────────────────────────────────────────
// Secuencia de seguimiento comercial (varios correos con distinto ángulo)
// generada a partir del análisis y la propuesta ya existentes para un negocio.
model AiOutreachSequence {
  id String @id @default(cuid())

  model        String // Modelo de IA usado
  placeId      String // Google Places ID del negocio (PlaceCache/BusinessAnalysis)
  businessName String

  context String @db.Text // Resumen usado como input (snapshot)
  steps   Json // { stepNumber, delayDays, angle, subject, body }[]

  rawOutput Json?

  archivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ai_outreach_sequences")
}

// ─── Competitor Radar ──────────────────────────────────────────────────────
// Informe de competidores cercanos generado con búsqueda web. 1:1 por negocio
// (placeId); volver a generarlo sobrescribe el informe anterior.
model CompetitorRadarReport {
  id String @id @default(cuid())

  placeId      String @unique
  businessName String
  model        String

  competitors Json // { name, website?, strengths[], weaknesses[] }[]
  gaps        Json // string[] — huecos de mercado detectados
  summary     String @db.Text

  sources   Json? // { title, url }[] — fuentes citadas por la búsqueda web
  rawOutput Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("competitor_radar_reports")
}

// ─── Call Prep Agent ───────────────────────────────────────────────────────
// Guión de llamada/reunión generado a partir de una propuesta comercial ya
// redactada (AiProposal). 1:1 con AiProposal.
model AiCallScript {
  id         String @id @default(cuid())
  proposalId String @unique

  model       String
  meetingType EmailMeetingType @default(CALL)

  agenda     Json // string[]
  keyPoints  Json // string[]
  objections Json // { objection, response }[]
  questions  Json // string[] — preguntas de descubrimiento
  nextSteps  Json // string[]

  rawOutput Json?

  archivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  proposal AiProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@map("ai_call_scripts")
}

// ─── Content/SEO Agent ─────────────────────────────────────────────────────
// Plan de contenido (ideas de posts + copy de landing) para un negocio
// analizado, apoyado en los hallazgos del web audit del Rastreador. 1:1 por
// negocio (placeId); volver a generarlo sobrescribe el plan anterior.
model AiContentPlan {
  id String @id @default(cuid())

  placeId      String @unique
  businessName String
  model        String

  topics      Json // { title, angle, keywords[], format }[]
  landingCopy Json // { headline, subheadline, ctaLabel, bullets[] }
  seoNotes    Json // string[] — basado en PlaceCache.webAudit.issues

  rawOutput Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ai_content_plans")
}

// ─── SEO Audit ──────────────────────────────────────────────────────────────
// Auditoría SEO profesional de una URL (de un negocio del CRM o cualquier
// web). Combina datos técnicos extraídos por fetch directo + un informe
// elaborado generado por IA (categorías, hallazgos, quick wins, keywords).
model AiSeoAudit {
  id String @id @default(cuid())

  url          String
  finalUrl     String?
  businessName String?
  model        String

  technical Json // SeoTechnicalData — datos extraídos del fetch
  report    Json // SeoReportOutput — informe elaborado por IA
  score     Int // 0-100, score técnico calculado

  rawOutput Json?

  archivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ai_seo_audits")
}

// ─── Transcript Analyzer ───────────────────────────────────────────────────
// Análisis de una transcripción de llamada/reunión pegada por el usuario:
// resumen, requisitos, objeciones, próximos pasos y sentimiento general.
model AiTranscriptAnalysis {
  id String @id @default(cuid())

  model        String
  businessName String?

  transcript String @db.Text
  summary    String @db.Text

  requirements Json // string[]
  objections   Json // { objection, response? }[]
  actionItems  Json // string[]
  sentiment    String // "positive" | "neutral" | "negative"

  rawOutput Json?

  archivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ai_transcript_analyses")
}
