# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — commit only the *.example templates, never real secrets
.env.local
.env*.local
.env*
!.env.example
!.env.production.example

# Certbot — certificados TLS emitidos en el servidor, nunca en el repo
nginx/certbot/conf/
nginx/certbot/www/

# exact ignore entries requested
.next/
node_modules/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma generated client (node_modules/.prisma/client — gitignored via node_modules rule)
