# .env.example — copiar a .env.local y completar valores reales.
# Este archivo es seguro para commitear: no contiene secretos.

# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Base de datos — Neon (https://neon.tech) ───────────────────────────────
# 1. Crea un proyecto en https://neon.tech (free tier)
# 2. Ve a: Connection Details → Connection string
# 3. Copia la URL completa (incluye ?sslmode=require)
# Formato: postgresql://[user]:[password]@[endpoint].neon.tech/[dbname]?sslmode=require
DATABASE_URL="postgresql://user:password@ep-xxx-yyy-zzz.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ─── Auth — NextAuth v5 (NZT-20) ────────────────────────────────────────────
# Genera AUTH_SECRET con: openssl rand -base64 32
AUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"
AUTH_TRUST_HOST=true

# Credenciales del usuario administrador privado.
# No habilita registro público — solo valida contra estos valores.
PRIVATE_ADMIN_EMAIL="admin@nztstudio.local"
PRIVATE_ADMIN_PASSWORD="your-secure-password-here"

# ─── IA (NZT-21+) ───────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ─── Local Business Analyzer — Sprint 3 (NZT-76+) ──────────────────────────
# Google Places API (New) — server-side ONLY. Never prefix with NEXT_PUBLIC_.
# Activate: Google Cloud Console → Places API (New) + Geocoding API
# Restrict key: IP restrictions for the server / no HTTP referrer restrictions
GOOGLE_PLACES_API_KEY=

# Analyzer usage limits (override defaults if needed)
ANALYZER_MAX_RESULTS=20
ANALYZER_MAX_RADIUS_METERS=2500
ANALYZER_CACHE_TTL_DAYS=7

# Optional: only needed if Google Maps JavaScript API is used in the browser (NZT-80+).
# Create a SEPARATE key restricted to: Maps JavaScript API + your domain only.
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=