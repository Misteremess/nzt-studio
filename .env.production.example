# ─── .env de producción para nzt.hyperfocus.es ───────────────────────────────
# Copia este archivo a `.env` en /opt/hyperfocus/nzt/:
#     cp .env.production.example .env && nano .env
#
# IMPORTANTE — passwords:
#   Siempre generarlas con `openssl rand -hex 24`.
#   NO usar base64: los caracteres +/= rompen la DATABASE_URL de forma silenciosa.
#
# Genera todos los secretos de una vez:
#   for v in POSTGRES_ROOT_PASSWORD NZT_DB_PASSWORD AUTH_SECRET TOTP_ENCRYPTION_KEY; do
#     echo "$v=$(openssl rand -hex 24)"; done

# ─── Postgres ─────────────────────────────────────────────────────────────────
# Contraseña del superuser postgres (solo la usa el propio contenedor postgres).
POSTGRES_ROOT_PASSWORD=genera-con-openssl-rand-hex-24

# Contraseña del usuario nzt (usuario de la app, solo puede operar la BD nzt).
# DEBE COINCIDIR con la que se usa en DATABASE_URL.
NZT_DB_PASSWORD=genera-con-openssl-rand-hex-24

# ─── App ──────────────────────────────────────────────────────────────────────
# El hostname `postgres` es el nombre del servicio en docker-compose.production.yml.
DATABASE_URL=postgresql://nzt:PONER-NZT_DB_PASSWORD-AQUI@postgres:5432/nzt

# ─── Auth — NextAuth v5 + 2FA ────────────────────────────────────────────────
AUTH_SECRET=genera-con-openssl-rand-hex-24
AUTH_TRUST_HOST=true
# AUTH_URL y NEXT_PUBLIC_APP_URL están hardcodeados en docker-compose.production.yml
# para garantizar que siempre apuntan al dominio correcto.

# Clave de cifrado de secretos TOTP en reposo. NO cambiar una vez en uso:
# los 2FA ya enrolados dejarían de validar.
TOTP_ENCRYPTION_KEY=genera-con-openssl-rand-hex-24

# ─── API keys ─────────────────────────────────────────────────────────────────
# Rellenar con las claves de la cuenta de empresa (no personales).
# Server-side ONLY — nunca prefijar con NEXT_PUBLIC_.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_PLACES_API_KEY=

# ─── Rastreador (opcionales — los valores por defecto son razonables) ─────────
ANALYZER_MAX_RESULTS=20
ANALYZER_MAX_RADIUS_METERS=2500
ANALYZER_CACHE_TTL_DAYS=7
