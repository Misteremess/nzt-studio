# ─── Plantilla de entorno para el despliegue en VPS (Docker Compose) ─────────
# Copia este fichero a `.env` en la raíz del proyecto en el servidor:
#     cp .env.production.example .env
# y rellena los valores reales. `.env` NO se commitea (está en .gitignore).
# Docker Compose lee `.env` automáticamente.

# ─── Postgres (servicio "db" del compose) ────────────────────────────────────
POSTGRES_USER=nzt
POSTGRES_PASSWORD=cambia-esta-password-de-postgres
POSTGRES_DB=nzt

# ─── App ─────────────────────────────────────────────────────────────────────
# La app se conecta al Postgres del compose por el nombre de servicio "db".
# El usuario/clave/nombre deben COINCIDIR con los POSTGRES_* de arriba.
DATABASE_URL=postgresql://nzt:cambia-esta-password-de-postgres@db:5432/nzt

# URL pública del cockpit (tu dominio cuando tengas TLS).
NEXT_PUBLIC_APP_URL=https://tu-dominio.com

# ─── Auth (NextAuth v5 + 2FA) ────────────────────────────────────────────────
# Genera cada secreto con: openssl rand -base64 32
AUTH_SECRET=genera-uno-con-openssl-rand-base64-32
AUTH_TRUST_HOST=true
# La app corre detrás de Nginx: indica la URL canónica para las callbacks.
AUTH_URL=https://tu-dominio.com

# Clave para cifrar los secretos TOTP en reposo. Si la cambias, los 2FA ya
# enrolados dejarán de validar (habría que hacer reset-2fa a cada usuario).
TOTP_ENCRYPTION_KEY=genera-uno-con-openssl-rand-base64-32

# ─── API keys de IA y datos ──────────────────────────────────────────────────
# Server-side ONLY — nunca prefijar con NEXT_PUBLIC_.
# Sustituir más adelante por claves de la cuenta de la empresa (no personales).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_PLACES_API_KEY=

# Límites del Rastreador (opcionales, valores por defecto razonables).
ANALYZER_MAX_RESULTS=20
ANALYZER_MAX_RADIUS_METERS=2500
ANALYZER_CACHE_TTL_DAYS=7
